<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Painted Veil — Illustrated by Zixuan Wang</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300;1,400&display=swap" rel="stylesheet">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: #1a0a04;
    font-family: 'Cormorant Garamond', Georgia, serif;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    user-select: none;
  }

  /* BOOK CONTAINER */
  #book-wrap {
    position: relative;
    width: min(420px, 92vw);
    height: min(620px, 88vh);
    perspective: 2000px;
  }

  /* Each PAGE */
  .page {
    position: absolute;
    inset: 0;
    border-radius: 4px;
    overflow: hidden;
    transform-origin: left center;
    transform-style: preserve-3d;
    transition: transform 0.65s cubic-bezier(0.645, 0.045, 0.355, 1.000),
                opacity 0.4s ease;
    box-shadow: 6px 6px 40px rgba(0,0,0,0.6);
    cursor: pointer;
  }

  .page img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* crop phone UI chrome from screenshots */
    object-position: center 12%;
  }

  /* page turning states */
  .page.turned {
    transform: rotateY(-180deg);
    opacity: 0;
    pointer-events: none;
  }

  .page.current {
    transform: rotateY(0deg);
    opacity: 1;
    z-index: 10;
  }

  .page.next {
    transform: rotateY(0deg);
    opacity: 1;
    z-index: 5;
  }

  .page.hidden {
    opacity: 0;
    pointer-events: none;
    z-index: 1;
  }

  /* TURN ANIMATION */
  .page.turning {
    transform: rotateY(-90deg);
    opacity: 0.6;
    z-index: 20;
    transition: transform 0.32s ease-in, opacity 0.32s ease-in;
  }

  /* NAVIGATION */
  #nav {
    position: fixed;
    bottom: 1.8rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 1.6rem;
    z-index: 100;
  }

  .nav-btn {
    background: rgba(201,168,76,0.15);
    border: 1px solid rgba(201,168,76,0.45);
    color: #C9A84C;
    font-family: 'Cormorant Garamond', serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.55rem 1.4rem;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .nav-btn:hover { background: rgba(201,168,76,0.28); }
  .nav-btn:disabled { opacity: 0.25; cursor: default; }

  #page-counter {
    font-size: 12px;
    letter-spacing: 0.2em;
    color: rgba(201,168,76,0.6);
    font-style: italic;
    min-width: 60px;
    text-align: center;
  }

  /* TITLE */
  #title-bar {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    z-index: 100;
  }
  #title-bar h1 {
    font-size: 13px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.7);
    font-weight: 300;
  }
  #title-bar p {
    font-size: 11px;
    letter-spacing: 0.18em;
    color: rgba(201,168,76,0.38);
    margin-top: 3px;
    font-style: italic;
  }

  /* CLICK AREAS on book */
  #click-prev {
    position: absolute;
    left: 0; top: 0;
    width: 30%;
    height: 100%;
    z-index: 50;
    cursor: w-resize;
  }
  #click-next {
    position: absolute;
    right: 0; top: 0;
    width: 70%;
    height: 100%;
    z-index: 50;
    cursor: e-resize;
  }

  /* SWIPE hint on first load */
  #hint {
    position: fixed;
    bottom: 5.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: rgba(201,168,76,0.4);
    font-style: italic;
    animation: hintFade 3s ease 1.5s forwards;
    opacity: 0;
  }
  @keyframes hintFade {
    0% { opacity:0; } 20% { opacity:1; } 80% { opacity:1; } 100% { opacity:0; }
  }
</style>
</head>
<body>

<div id="title-bar">
  <h1>The Painted Veil</h1>
  <p>Illustrated by Zixuan Wang</p>
</div>

<div id="book-wrap">
  <!-- pages inserted by JS -->
  <div id="click-prev" onclick="prevPage()"></div>
  <div id="click-next" onclick="nextPage()"></div>
</div>

<div id="nav">
  <button class="nav-btn" id="btn-prev" onclick="prevPage()" disabled>← Prev</button>
  <span id="page-counter">1 / 15</span>
  <button class="nav-btn" id="btn-next" onclick="nextPage()">Next →</button>
</div>

<div id="hint">Tap right to turn page</div>

<script>
  const pages = [
    'veil_p01_cover.png',
    'veil_p02_text.png',
    'veil_p03_candle.png',
    'veil_p04_text.png',
    'veil_p05_illus.png',
    'veil_p06_text.png',
    'veil_p07_illus.png',
    'veil_p08_illus.png',
    'veil_p09_text.png',
    'veil_p10_illus.png',
    'veil_p11_text.png',
    'veil_p12_text.png',
    'veil_p13_illus.png',
    'veil_p14_text.png',
    'veil_p15_illus.png',
  ];

  const wrap = document.getElementById('book-wrap');
  const counter = document.getElementById('page-counter');
  const btnPrev = document.getElementById('btn-prev');
  const btnNext = document.getElementById('btn-next');
  let current = 0;
  let animating = false;

  // Build DOM
  const els = pages.map((src, i) => {
    const div = document.createElement('div');
    div.className = 'page ' + (i === 0 ? 'current' : 'hidden');
    div.style.zIndex = pages.length - i;
    const img = document.createElement('img');
    img.src = src;
    img.alt = 'Page ' + (i + 1);
    div.appendChild(img);
    // insert before click areas
    wrap.insertBefore(div, document.getElementById('click-prev'));
    return div;
  });

  function updateUI() {
    counter.textContent = (current + 1) + ' / ' + pages.length;
    btnPrev.disabled = current === 0;
    btnNext.disabled = current === pages.length - 1;
  }

  function nextPage() {
    if (animating || current >= pages.length - 1) return;
    animating = true;
    const cur = els[current];
    const nxt = els[current + 1];

    // bring next into view beneath current
    nxt.className = 'page next';
    nxt.style.zIndex = 5;

    // animate current turning away
    cur.style.zIndex = 20;
    cur.classList.add('turning');

    setTimeout(() => {
      cur.className = 'page turned';
      nxt.className = 'page current';
      nxt.style.zIndex = 10;
      current++;
      updateUI();
      animating = false;
    }, 320);
  }

  function prevPage() {
    if (animating || current <= 0) return;
    animating = true;
    const cur = els[current];
    const prv = els[current - 1];

    // un-turn previous page
    prv.className = 'page current';
    prv.style.zIndex = 20;

    cur.className = 'page hidden';
    current--;
    updateUI();
    animating = false;
  }

  // Keyboard
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === ' ') nextPage();
    if (e.key === 'ArrowLeft') prevPage();
  });

  // Touch swipe
  let touchStartX = 0;
  wrap.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive:true });
  wrap.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (dx < -40) nextPage();
    if (dx > 40) prevPage();
  });

  updateUI();
</script>
</body>
</html>
